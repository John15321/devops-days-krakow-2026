vars: {
  d2-config: {
    pad: 36
    sketch: false
  }
}

classes: {
  step: {
    style: {
      fill: "#FFFFFF"
      stroke: "#12172B"
      stroke-width: 3
      font-color: "#12172B"
      font-size: 36
      border-radius: 14
      shadow: true
      bold: true
    }
  }
  arrow: {
    style: {
      stroke: "#09BAC8"
      stroke-width: 6
      font-color: "#12172B"
      font-size: 24
      bold: true
    }
  }
}

direction: down

config: "Declarative Configuration\n(Ignition, Butane)" { class: step }
substrate: "Cloud · Virtualization · Bare Metal" { class: step }
containers: "Containers (Podman, K8s, systemd)" { class: step }

config -> substrate: "provisions" { class: arrow }
substrate -> containers: "runs" { class: arrow }
